@app.route('/track_orders')
def track_orders():
    if 'customer' not in session:
        return redirect(url_for('customer_login'))

    customer_email = session['customer']

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    cursor.execute("""
        SELECT 
            o.id,
            o.quantity,
            o.status,
            s.supplier_name,
            s.email AS supplier_email,
            s.phone AS supplier_phone,
            s.address AS supplier_address,
            m.name AS medicine_name,
            m.image
        FROM orders o
        LEFT JOIN medicines m ON o.medicine_id = m.id
        LEFT JOIN suppliers s ON o.supplier_name = s.supplier_name
        WHERE o.customer_email = %s
        ORDER BY o.id DESC
    """, (customer_email,))

    orders = cursor.fetchall()

    cursor.close()
    conn.close()

    return render_template("track_orders.html", orders=orders)




