@app.route('/update_order_status', methods=['GET', 'POST'])
def update_order_status():
    if 'customer' not in session:
        return redirect(url_for('customer_login'))

    customer_email = session['customer']
    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    if request.method == 'POST':
        order_id = request.form.get('order_id')
        new_status = request.form.get('status')

        if order_id and new_status:
            # Update only if the order belongs to this customer
            cursor.execute("""
                UPDATE orders 
                SET status=%s 
                WHERE id=%s AND customer_email=%s
            """, (new_status, order_id, customer_email))
            conn.commit()
            flash(f"Order #{order_id} status updated to '{new_status}'!", "success")
        else:
            flash("Invalid request!", "danger")

        return redirect(url_for('update_order_status'))

    # GET request: fetch all orders for this customer
    cursor.execute("""
        SELECT o.id, m.name AS medicine_name, o.quantity, o.status
        FROM orders o
        JOIN medicines m ON o.medicine_id = m.id
        WHERE o.customer_email = %s
        ORDER BY o.id DESC
    """, (customer_email,))

    orders = cursor.fetchall()
    cursor.close()
    conn.close()

    return render_template('update_order_status.html', orders=orders)

