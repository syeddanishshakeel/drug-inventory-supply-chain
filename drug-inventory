@app.route('/payment_page', methods=['GET', 'POST'])
def payment_page():
    if 'customer' not in session:
        return redirect(url_for('customer_login'))

    med_id = session.get('payment_medicine_id')
    quantity = int(session.get('payment_quantity'))

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    # Get medicine details
    cursor.execute("SELECT * FROM medicines WHERE id=%s", (med_id,))
    medicine = cursor.fetchone()

    if not medicine:
        flash("Medicine not found!", "danger")
        return redirect(url_for('order_medicine'))

    total_price = medicine['price'] * quantity

    if request.method == 'POST':

        # 🔹 Re-check stock before confirming
        if medicine['stock'] >= quantity:

            # Insert order
            cursor.execute("""
                INSERT INTO orders (customer_email, medicine_id, quantity, status)
                VALUES (%s, %s, %s, %s)
            """, (session['customer'], med_id, quantity, "Paid"))

            # Reduce stock
            cursor.execute("""
                UPDATE medicines
                SET stock = stock - %s
                WHERE id = %s
            """, (quantity, med_id))

            conn.commit()

            cursor.close()
            conn.close()

            # Clear temporary session values
            session.pop('payment_medicine_id', None)
            session.pop('payment_quantity', None)

            # 🔥 Redirect to success animation page
            return redirect(url_for('payment_success'))

        else:
            cursor.close()
            conn.close()
            flash("Stock not available!", "danger")
            return redirect(url_for('order_medicine'))

    cursor.close()
    conn.close()

    return render_template('payment_page.html',
                           medicine=medicine,
                           quantity=quantity,
                           total_price=total_price)

