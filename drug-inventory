@app.route('/update_medicine', methods=['GET', 'POST'])
def update_medicine():

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    # STEP 1: Search Medicine by ID
    if request.method == 'POST' and 'search_id' in request.form:
        med_id = request.form['search_id']   # ✅ Correct

        cursor.execute("SELECT * FROM medicines WHERE id=%s", (med_id,))
        medicine = cursor.fetchone()

        if medicine:
            cursor.close()
            conn.close()
            return render_template('update_medicine.html', medicine=medicine)
        else:
            flash("Medicine ID Not Found!", "danger")

    # STEP 2: Update Medicine
    if request.method == 'POST' and 'update_id' in request.form:
        med_id = request.form['update_id']
        name = request.form['name']
        price = request.form['price']
        disease = request.form['disease']
        stock = request.form['stock']

        image = request.files['image']

        if image and image.filename != "":
            filename = secure_filename(image.filename)
            image.save(os.path.join(app.config['UPLOAD_FOLDER'], filename))

            cursor.execute("""
                UPDATE medicines 
                SET name=%s, price=%s, disease=%s, stock=%s, image=%s
                WHERE id=%s
            """, (name, price, disease, stock, filename, med_id))
        else:
            cursor.execute("""
                UPDATE medicines 
                SET name=%s, price=%s, disease=%s, stock=%s
                WHERE id=%s
            """, (name, price, disease, stock, med_id))

        conn.commit()
        cursor.close()
        conn.close()

        flash("Medicine Updated Successfully!", "success")
        return redirect(url_for('update_medicine'))

    cursor.close()
    conn.close()
    return render_template('search_medicine.html')
